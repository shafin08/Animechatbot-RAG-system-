# ============================================================
# Anime RAG — Environment Variables
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to GitHub
# ============================================================

# --- Required ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- LangSmith (for tracing & evals) ---
# Sign up free at https://smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=anime-rag
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- App Config ---
ANIME_SERIES=naruto           # which wiki to scrape
MAX_PAGES=500                 # how many wiki pages to scrape
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=10            # chunks to retrieve before reranking
TOP_K_RERANK=5                # chunks to pass to LLM after reranking
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
